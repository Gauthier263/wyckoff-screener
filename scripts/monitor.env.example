# Copie ce fichier en scripts/monitor.env et remplis tes valeurs.
# Il est sourcé par monitor_cron.sh — NE PAS committer monitor.env (secrets).

# --- Alerte Telegram (sinon : alerte console seule, captée dans le log) ---
export TG_BOT_TOKEN="123456:ABC-ton-token-botfather"
export TG_CHAT_ID="123456789"

# --- Paramètres du suivi ---
export WS_SYMBOLS="BTC/USDT"        # une ou plusieurs paires séparées par des espaces
export WS_TIMEFRAME="1h"            # 1h, 4h, 5m, ...
export WS_EXPECT="distribution"     # accumulation | distribution
